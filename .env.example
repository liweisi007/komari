# Image published by this fork. GitHub Actions publishes to ghcr.io/<owner>/<repo>:latest.
KOMARI_IMAGE=ghcr.io/your_github_username/komari:latest
KOMARI_VERSION=

# GitHub backup repository.
GH_BACKUP_USER=your_github_username
GH_REPO=your_private_repo_name
GH_BACKUP_BRANCH=main
GH_PAT=your_github_personal_access_token
GH_EMAIL=your_github_email@example.com

# Komari admin account used on first initialization.
ADMIN_USERNAME=yourusername
ADMIN_PASSWORD=yourpassword

# Cloudflare tunnel.
ARGO_DOMAIN=your-argo-domain.com
KOMARI_CLOUDFLARED_TOKEN=eyJxxxxx

# Backup schedule, UTC.
BACKUP_TIME="0 20 * * *"
BACKUP_DAYS=10
KOMARI_LOCK_TIMEOUT_SECONDS=60

# Script auto update. Set to 1 to disable daily script updates.
NO_AUTO_RENEW=

# Caddy reverse proxy.
CADDY_PROXY_PORT=8001
CADDY_VERSION=2.9.1
XRAY_VLESS_PORT=8002
XRAY_VMESS_PORT=8003

# Disable Komari web SSH/terminal and remote command features by default. Set both to 0 to allow them.
KOMARI_DISABLE_WEB_SSH=1
KOMARI_DISABLE_REMOTE=1

# Optional subscription endpoint.
UUID=
CF_IP=ip.sb
SUB_HOST=
SUB_SNI=
SUB_NAME=komari
